{
  "name": "TVC VTVL UGRP - ROS2 Jazzy Development",
  "dockerFile": "../Dockerfile",
  "context": "..",
  "remoteUser": "ros",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "postCreateCommand": "bash -c 'sudo chown -R ros:ros /workspace && rosdep install --from-paths /workspace/src -i -y --rosdistro jazzy 2>/dev/null || echo \"No src/ directory yet (normal before Phase 4)\"'",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-ros.ros"
      ],
      "settings": {
        "ROS.sourceSpaceDir": "${workspaceFolder}/src",
        "files.exclude": {
          "**/__pycache__": true,
          "build/**": true,
          "install/**": true,
          "log/**": true
        }
      }
    }
  }
}
